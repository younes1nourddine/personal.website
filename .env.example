# Vorlage. Echte Werte NUR in Vercel > Settings > Environment Variables setzen,
# niemals in dieses Repo committen. Diese Datei enthaelt absichtlich keine Secrets.

# --- Kontaktformular und Lead-Formular (Resend) ---
RESEND_API_KEY=dein_resend_api_key
CONTACT_TO_EMAIL=kontakt@deine-domain.de
CONTACT_FROM_EMAIL=website@deine-domain.de

# --- Website-Pruefung im Digitalisierungs-Check (optional) ---
# Ohne Schluessel funktioniert es auch, nur mit kleinerem Kontingent.
PAGESPEED_API_KEY=optionaler_google_api_key

# --- KI-Assistent Demo ---
# Waehle EINEN Anbieter: "openai" | "cloudflare" | "anthropic"
AI_PROVIDER=openai

# Variante "openai" (deckt Mistral, Groq, OpenRouter, Together, DeepInfra ...)
# Mistral:  AI_BASE_URL=https://api.mistral.ai/v1
# Groq:     AI_BASE_URL=https://api.groq.com/openai/v1
AI_BASE_URL=https://api.mistral.ai/v1
AI_API_KEY=dein_anbieter_api_key
AI_MODEL=mistral-small-latest

# Variante "cloudflare" (Workers AI, kostenloses Tageskontingent)
# CF_ACCOUNT_ID=deine_account_id
# CF_API_TOKEN=dein_workers_ai_token
# AI_MODEL=@cf/meta/llama-3.1-8b-instruct

# Variante "anthropic" (Claude)
# ANTHROPIC_API_KEY=dein_anthropic_key
# AI_MODEL=claude-haiku-4-5
# Bei claude-sonnet-5 sinnvoll, sonst denkt das Modell standardmaessig mit:
# ANTHROPIC_DISABLE_THINKING=true
